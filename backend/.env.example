# MirrorMind — Environment Variables

# Groq API Key for ultra-fast Llama-3 inference
# Get free at https://console.groq.com/keys
GROQ_API_KEY=your_key_here

# Alternatively, you can use OpenAI or Gemini
# OPENAI_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here

# CORS Origin for frontend URL (defaults to localhost)
# CORS_ORIGINS=http://localhost:5173
